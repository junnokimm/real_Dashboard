# Shared LLM settings used by chat/tool rewriting.
LLM_PROVIDER=openai
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4.1-mini

# Insights-specific LLM settings used by /api/insights.
UX_INSIGHTS_PROVIDER=openai
UX_INSIGHTS_API_KEY=<your-openai-api-key>
UX_INSIGHTS_MODEL=gpt-4.1-mini
# Optional: override API base URL for OpenAI-compatible providers.
# UX_INSIGHTS_BASE_URL=https://api.openai.com/v1

# Existing UX_SDK server port
PORT=3001

# Phase 4 infra bootstrap
ENABLE_KAFKA_DUAL_WRITE=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ux-sdk-service
KAFKA_TOPIC_EVENTS=ux.events.raw
KAFKA_CONSUMER_GROUP_ID=ux-sdk-event-consumer
KAFKA_CONSUMER_FROM_BEGINNING=false

ENABLE_REDIS_SESSION_STORE=false
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=uxsdk
REDIS_SESSION_TTL_SEC=1800
REDIS_ASSIGNMENT_TTL_SEC=2592000
